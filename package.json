{
  "name": "lorem-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev:ui": "pnpm --filter ui dev",
    "dev:demo": "pnpm --filter demo dev",
    "dev:all": "pnpm run dev:ui & pnpm run dev:demo",
    "build": "pnpm build:ui && pnpm build:demo && pnpm build:storybook",
    "build:ui": "pnpm --filter ui build",
    "build:demo": "pnpm --filter demo build",
    "build:storybook": "pnpm --filter ui exec storybook build",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write 'packages/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "lint:ui": "eslint packages/ui/src/",
    "lint:demo": "eslint packages/demo/src/",
    "format:ui": "prettier --write 'packages/ui/src/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "format:demo": "prettier --write 'packages/demo/src/**/*.{ts,tsx,js,jsx,json,css,md}'",
    "lint:all": "pnpm lint",
    "format:all": "pnpm format",
    "test:unit": "pnpm --filter ui test",
    "test:unit:watch": "pnpm --filter ui test --watch",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:suggest": "tsx scripts/testing-agent.ts",
    "test:implement": "tsx scripts/implement-tests.ts",
    "test:cleanup": "tsx scripts/cleanup-suggestions.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.73",
    "@anthropic-ai/sdk": "^0.78.0",
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/jest": "^0.2.3",
    "@storybook/testing-library": "^0.2.2",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.12.0",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.40.0",
    "zod": "^4.3.6"
  }
}
